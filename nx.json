{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "release": {
    "projects": [ "packages/*" ],
    "releaseTagPattern": "{projectName}@{version}",
    "version": {
      "versionActions": "./tools/typst-version-actions.js",
      "currentVersionResolver": "disk",
      "versionPrefix": ""
    },
    "changelog": {
      "projectChangelogs": true
    }
  }
}
